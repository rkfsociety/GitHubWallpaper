    "properties": {
      "githubTokenHint": {
        "order": 0,
        "type": "text",
        "text": "GitHub token (PAT) — скопируйте ссылку для создания:"
      },
      "githubTokenUrl": {
        "order": 1,
        "text": " ",
        "type": "textinput",
        "value": "https://github.com/settings/personal-access-tokens/new"
      },
      "githubToken": {
        "order": 2,
        "text": "Токен",
        "type": "textinput",
        "value": ""
      },
      "githubTokenPermissions": {
        "order": 3,
        "type": "text",
        "text": "Права токена (Read): Metadata, Contents, Issues, Pull requests, Actions. Репозитории — только те, что в обоях. Без токена: 60 req/ч, только публичные."
